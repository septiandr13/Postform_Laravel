{
  "framework": null,
  "buildCommand": "npm ci && npm run build",
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.7.3",
      "config": {
        "includeFiles": [
          "public/**",
          "vendor/**",
          "bootstrap/app.php",
          "bootstrap/providers.php",
          "app/**",
          "routes/**",
          "config/**",
          "database/**",
          "resources/views/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/storage/(.*)", "dest": "/public/storage/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
